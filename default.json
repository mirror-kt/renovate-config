{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:base",
        ":timezone(Asia/Tokyo)",
        "group:monorepos",
        "helpers:pinGitHubActionDigests"
    ],
    "dockerfile": {
        "fileMatch": [
            "^(?:.*\\.)?Dockerfile$"
        ]
    },
    "packageRules": [
        {
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "automerge": true
        }
    ],
    "lockFileMaintenance": {
        "enabled": true,
        "recreateWhen": "always",
        "rebaseStalePrs": true,
        "schedule": [
            "before 4am on monday"
        ]
    },
    "commitMessagePrefix": "⬆️ ",
    "labels": [
        "dependencies"
    ],
    "configMigration": true,
    "minimumReleaseAge": "7 days",
    "prCreation": "not-pending",
    "internalChecksFilter": "strict",
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0,
    "customManagers": [
        {
            "customType": "jsonata",
            "fileFormat": "json",
            "managerFilePatterns": [
                "/package.json$/"
            ],
            "matchStrings": [
                "{ 'currentValue': pnpm.executionEnv.nodeVersion }"
            ],
            "datasourceTemplate": "node-version",
            "depNameTemplate": "node"
        },
        {
            "customType": "jsonata",
            "fileFormat": "yaml",
            "managerFilePatterns": [
                "/pnpm-workspace.yaml$/"
            ],
            "matchStrings": [
                "{ 'currentValue': executionEnv.nodeVersion }"
            ],
            "datasourceTemplate": "node-version",
            "depNameTemplate": "node"
        }
    ]
}
